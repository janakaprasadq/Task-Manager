{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/api",
            "entrypoint": "server.js",
            "runtime": "node"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1",
            "check": true
        }
    ]
}